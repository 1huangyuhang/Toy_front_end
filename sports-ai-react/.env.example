## 预签名上传（方案 B）示例配置
## 复制为 .env 后填写真实值

# 对象存储（S3 或 S3 兼容）
S3_BUCKET=your-bucket
S3_REGION=ap-southeast-1
S3_ACCESS_KEY_ID=your-access-key-id
S3_SECRET_ACCESS_KEY=your-secret-access-key

# 如果是 S3 兼容（MinIO/部分国内厂商），通常需要 endpoint
S3_ENDPOINT=https://s3.your-provider.com
S3_FORCE_PATH_STYLE=false

# 返回给前端的“可访问地址”（建议用 CDN 域名）
# 例：https://media.yourdomain.com
PUBLIC_BASE_URL=https://media.yourdomain.com

# 存储 key 前缀
KEY_PREFIX=uploads/

# 本地签名服务端口（vite 会通过代理转发 /api 到这里）
PORT=8787

# 登录态签名密钥（开发环境也建议改一下）
JWT_SECRET=change-me-in-dev

